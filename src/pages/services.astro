---
import Layout from "@layouts/Layout.astro";
import NavigationBar from "@components/Navigation";
import ServiceBlock from "@components/Services/ServiceBlock.astro";
import Footer from "@components/Footer.astro";
---

<Layout title="AURA Beauty Salon | Servicios">
  <NavigationBar client:load />
  <!--- Banner Section --->
  <section
    id="all-services-banner"
    role="banner"
    class="relative w-full min-h-[90vh] max-h-[90vh] flex flex-col justify-center items-center"
    aria-labelledby="services-title"
  >
    <div class="w-full absolute right-0 -z-10 min-h-[90vh] max-h-[90vh]">
      <img
        class="w-full min-h-[90vh] max-h-[90vh] object-cover object-top -z-15"
        src="/images/services/all-services-banner.webp"
        alt="Servicios de AURA Beauty Salon en San Francisco, Ciudad de Panamá"
      >
    </div>
    <div class="flex flex-col justify-center items-center gap-5 relative px-3 mb-10">
      <h1 class="text-4xl text-center text-white text-shadow" id="services-title">
        Tratamientos diseñados para tu estilo
      </h1>
      <p class="text-center md:w-8/12 text-xl text-white text-shadow">
        En AURA Beauty Salon ofrecemos servicios profesionales de cabello, uñas, pestañas y más. Cada tratamiento está pensado con técnica, cuidado y atención personalizada.
      </p>
      <div class="flex justify-center items-center gap-5">
        <a
          href="#all-services-section"
          class="white-button text-white"
          title="Ver todos los servicios de AURA Beauty Salon"
          aria-label="Ver todos los servicios que ofrecemos"
        >
          Ver todos los servicios
        </a>
        <a
          href="https://wa.me/50767925695"
          target="_blank"
          rel="noopener noreferrer"
          class="white-button text-white"
          title="Agendar cita por WhatsApp"
          aria-label="Agendar cita por WhatsApp"
        >
          Agendar por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <main>
    <section class="w-full" aria-label="Todos los servicios de AURA Beauty Salon" id="all-services-section">
      <ServiceBlock
        image="/images/services/hair-styling-service.webp"
        title="Cabello"
        slogan="Tu cabello, transformado con técnica y cuidado."
        description="Desde cortes de precisión y peinados hasta balayage, morenas iluminadas, mechas y tonalización. Nuestras especialistas trabajan para que tu cabello luzca exactamente como lo imaginaste, con productos de calidad y atención personalizada. También ofrecemos cobertura de canas con resultados naturales y duraderos."
      />
      <ServiceBlock
        image="/images/services/massage-service.webp"
        title="Rizos / Curly Hair"
        slogan="Cuidado especializado para cada tipo de rizo."
        description="El cabello rizado merece técnica y conocimiento específico. En AURA trabajamos con definición de rizos, hidratación profunda, coloración adaptada al tipo de cabello y métodos de cuidado para curly hair. Cada resultado es natural, saludable y lleno de vida. (Imagen de referencia — CONFIRMAR CON CLIENTE foto real)"
      />
      <ServiceBlock
        image="/images/services/nails-service.webp"
        title="Uñas"
        slogan="Diseños que hablan por ti."
        description="Manicure, pedicure, rubber nails, esmalte semipermanente y diseños personalizados. Trabajamos con técnica y precisión para que tus uñas reflejen tu personalidad en cada detalle. Cada visita es una experiencia de cuidado completo para tus manos y pies."
      />
      <div id="pestanas">
        <ServiceBlock
          image="/images/services/skin-care-service.webp"
          title="Pestañas"
          slogan="Una mirada que lo dice todo."
          description="Servicios profesionales de lashes para transformar tu mirada y realzar tu belleza natural. Consulta con nuestro equipo sobre los servicios disponibles de pestañas. (CONFIRMAR CON CLIENTE: lifting, extensiones, laminado u otros servicios exactos)"
        />
      </div>
      <div id="rizos">
        <ServiceBlock
          image="/images/services/hair-styling-service.webp"
          title="Tratamientos capilares"
          slogan="Hidratación, fuerza y brillo desde la raíz."
          description="Tratamientos de hidratación profunda, alisado y recuperación capilar para devolver vida y brillo a tu cabello. También contamos con Ybera Black Diva y otros tratamientos regeneradores. (CONFIRMAR CON CLIENTE: keratina, cirugía capilar u otros alisados específicos)"
        />
      </div>
    </section>
  </main>
  <Footer />
</Layout>

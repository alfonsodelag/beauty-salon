---
import { homeBannerImages } from '@data/homeBannerImages';

import Layout from '../layouts/Layout.astro';
import NavigationBar from '@components/Navigation';
import BannerSlider from '@components/Home/BannerSlider';
import ServiceCard from '@components/Home/ServiceCard.astro';
import BusinessHours from '@components/BusinessHours.astro';
import Footer from '@components/Footer.astro';
---

<Layout title="AURA Beauty Salon | Salón de belleza en San Francisco, Panamá">
	<NavigationBar client:load />
	<!--- Banner Section --->
	<section class="home-banner-wrapper min-h-screen w-full relative over-hidden">
		<article
		class="absolute top-1/2 left-1/2 z-10 min-w-56 max-w-xl -translate-x-1/2 -translate-y-1/2
    bg-white/10 backdrop-blur-xs rounded-sm p-6 shadow-xl text-center text-white space-y-4"
		>
			<h1 class="text-4xl md:text-5xl font-bold drop-shadow-md text-shadow tracking-wide">
				Donde la belleza toma forma
			</h1>
			<p class="text-lg md:text-xl leading-relaxed drop-shadow-sm text-shadow">
      	Cabello, uñas, pestañas y buen café en San Francisco, Ciudad de Panamá.
    	</p>
			<div class="flex flex-col sm:flex-row gap-3 justify-center items-center mt-4">
				<a
					href="https://wa.me/50767925695"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-block px-6 py-3 bg-[#6F5141] text-white text-base md:text-lg
					hover:bg-[#AE9380] transition-all duration-300 text-shadow hover-shadowless"
				>
					Agendar cita por WhatsApp
				</a>
				<a
					href="/services"
					class="inline-block px-6 py-3 border-2 border-[#FFE7CD] text-white text-base md:text-lg
					hover:bg-[#FFE7CD]/20 transition-all duration-300 text-shadow hover-shadowless"
				>
					Ver servicios
				</a>
			</div>
		</article>
		<BannerSlider images={homeBannerImages} client:visible />
	</section>
	<!--- Services Section --->
	<section
		class="min-h-screen flex flex-col justify-center items-center py-10 bg-[#2F2521]"
		aria-labelledby="home-services-title"
	>
		<h2 class="capital text-4xl text-center mb-4 text-white" id="home-services-title">
			nuestros servicios
		</h2>
		<p class="text-center max-w-8/12 text-white">
			En AURA Beauty Salon ofrecemos tratamientos diseñados para realzar tu belleza natural. Desde cabello hasta uñas y pestañas, cada servicio está pensado con técnica, cuidado y atención personalizada.
		</p>
		<article
			class="flex flex-col sm:flex-row flex-wrap justify-center items-center gap-2 py-5"
			aria-label="Main services cards section"
		>
			<ServiceCard
				src="/images/home-services/service-1.webp"
				alt="Estilista peinando el cabello de una clienta en AURA Beauty Salon"
				title="Cabello"
				description="Cortes, balayage, morenas iluminadas, mechas, tonalización y peinados. Tu cabello, transformado con técnica y cuidado personalizado."
			/>
			<ServiceCard
				src="/images/home-services/service-3.webp"
				alt="Especialista realizando manicure en AURA Beauty Salon"
				title="Uñas"
				description="Manicure, pedicure, rubber nails y diseños únicos. Porque tus manos y pies también merecen atención y estilo."
			/>
			<ServiceCard
				src="/images/home-services/service-2.webp"
				alt="Especialista en tratamiento de pestañas en AURA Beauty Salon"
				title="Pestañas"
				description="Servicios de lashes profesionales para transformar tu mirada y realzar tu belleza natural sin esfuerzo. (CONFIRMAR servicios exactos con el cliente)"
			/>
		</article>
		<a
			class="text-white white-button"
			href="/services"
			aria-label="Botón para ir a la página de servicios"
			title="Ver todos los servicios de AURA Beauty Salon"
		>
			Ver todos los servicios
		</a>
	</section>
	<!--- About Section --->
	<section class="flex flex-col py-10" aria-label="Información sobre AURA Beauty Salon">
		<!--- "Quiénes somos" --->
		<article
			class="w-full flex flex-col md:flex-row justify-center items-center gap-5 py-10"
			aria-labelledby="who-we-are-subtitle"
		>
			<div class="w-full md:w-5/12 flex flex-col gap-3 px-5">
				<h2 class="text-3xl text-[#6F5141]" id="who-we-are-subtitle">
					Sobre AURA...
				</h2>
				<p class="text-xl text-[#2F2521]">
					En AURA Beauty Salon creemos que ir al salón puede ser más que una cita: puede ser tu mejor terapia. Nuestro espacio combina técnica, calidez y una experiencia pensada para que te sientas cómoda desde que entras hasta que sales.
				</p>
				<a
					class="black-button"
					href="/about"
					aria-label="Botón para ir a la página Sobre Nosotros"
					title="Conocer más sobre AURA Beauty Salon"
				>
					conocer más
				</a>
			</div>
			<figure class="w-full md:w-5/12 flex justify-center items-center bg-[#FFF8F1]" id="who-we-are-fig">
				<img
					class="w-full hover:brightness-110 duration-300 transition-all"
					src="/images/home-about/home-about-1.webp"
					alt="Interior de AURA Beauty Salon en San Francisco, Ciudad de Panamá"
					title="AURA Beauty Salon"
					loading="lazy"
				>
			</figure>
		</article>
		<!--- "Nuestro compromiso" --->
		<article
			class="w-full flex flex-col md:flex-row justify-center items-center gap-5 py-10"
			aria-labelledby="our-commitment-subtitle"
		>
			<figure class="w-full md:w-5/12 flex justify-center items-center" id="our-commitment-fig">
				<img
					class="w-full hover:brightness-110 duration-300 transition-all"
					src="/images/home-about/home-about-2.webp"
					alt="Atención personalizada en AURA Beauty Salon"
					title="Cuidado personalizado en AURA Beauty Salon"
					loading="lazy"
				>
			</figure>
			<div class="w-full md:w-5/12 flex flex-col gap-3 px-5">
				<h2 class="text-3xl text-[#6F5141]" id="our-commitment-subtitle">
					Belleza con técnica y detalle
				</h2>
				<p class="text-xl text-[#2F2521]">
					Nos dedicamos a crear un ambiente relajante e inspirador donde la belleza se encuentra con el bienestar. Con productos de alta calidad, atención personalizada y un compromiso con la higiene y la excelencia, hacemos que tu visita sea siempre una experiencia premium.
				</p>
				<a
					class="black-button"
					href="/contact"
					aria-label="Botón para ir a la página de contacto"
					title="Contáctenos en AURA Beauty Salon"
				>
					contáctenos
				</a>
			</div>
		</article>
	</section>
	<!--- Business Hours Section --->
	<BusinessHours />
	<!--- Quote Section --->
	<section
		class="min-h-[80vh] flex flex-col justify-center items-center"
		id="home-quote-section"
		aria-label="Frase inspiradora de cierre"
	>
		<blockquote class="max-w-10/12 md:max-w-8/12 flex flex-col justify-center items-center text-shadow">
			<p class="text-3xl text-center text-white italic leading-relaxed">
				<q>Belleza, bienestar y confianza. Un espacio para verte y sentirte mejor.</q>
			</p>
			<cite class="mt-4 block text-2xl not-italic text-white">— AURA Beauty Salon</cite>
		</blockquote>
	</section>
	<!--- Footer Section --->
	<Footer />
</Layout>

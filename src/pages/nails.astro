---
import Layout from "@layouts/Layout.astro"
import NavigationBar from "@components/Navigation"
import NailServiceCard from "@components/Nails/NailServiceCard.astro"
import GallerySlider from "@components/Nails/GallerySlider"
import Footer from "@components/Footer.astro"
---

<Layout title="AURA Beauty Salon | Uñas">
  <NavigationBar client:load />
  <!--- Banner Section --->
  <section
    id="nails-banner"
    role="banner"
    class="relative w-full min-h-[90vh] max-h-[90vh] flex flex-col justify-center items-center"
    aria-labelledby="nails-title"
  >
    <div id="nails-banner-fig" class="w-full absolute right-0 -z-10 max-h-[90vh]">
      <img
        class="w-full max-h-[90vh] min-h-[90vh] object-cover object-top -z-15"
        src="/images/nails/nails-banner.webp"
        alt="Especialista en uñas trabajando en AURA Beauty Salon"
      >
    </div>
    <div class="flex flex-col justify-center items-center gap-5 relative px-3">
      <h1 class="text-4xl text-center text-white text-shadow" id="nails-title">
        Uñas con estilo y precisión
      </h1>
      <p class="text-center md:w-8/12 text-xl text-white text-shadow">
        Manicure, pedicure, rubber nails y diseños personalizados hechos con técnica y cuidado.
      </p>
      <div class="flex justify-center items-center gap-5 flex-wrap">
        <a
          href="https://wa.me/50767925695"
          target="_blank"
          rel="noopener noreferrer"
          class="white-button text-white"
          title="Agendar cita de uñas por WhatsApp"
          aria-label="Agendar cita en AURA Beauty Salon por WhatsApp"
        >
          Agendar cita
        </a>
        <a
          href="#nails-services-section"
          class="button-secondary"
          title="Ver servicios de uñas"
          aria-label="Ver servicios de uñas en AURA Beauty Salon"
        >
          Ver servicios
        </a>
      </div>
    </div>
  </section>
  <!--- Services Section --->
  <section
    class="flex flex-col justify-center items-center p-5"
    aria-labelledby="nails-services-title"
    id="nails-services-section"
  >
    <h2 class="text-3xl md:text-5xl font-bold my-10 text-[#6F5141]" id="nails-services-title">
      Nuestros servicios de uñas
    </h2>
    <div class="flex flex-col justify-center items-center md:flex-row md:items-start md:flex-wrap gap-7 py-5">
      <NailServiceCard
        title="Manicure clásica"
        image="/images/nails/nails-services/manicure.webp"
        description="Manicure tradicional que incluye limado y forma de uñas, cuidado de cutículas, masaje de manos relajante y esmalte a tu elección."
      />
      <NailServiceCard
        title="Uñas de gel"
        image="/images/nails/nails-services/gel-nails.webp"
        description="Brillo y color de larga duración con nuestra manicure de gel. Acabado perfecto, resistente al chip, que seca al instante."
      />
      <NailServiceCard
        title="Rubber nails"
        image="/images/nails/nails-services/nails-repair.webp"
        description="Técnica de alto rendimiento que ofrece mayor durabilidad y flexibilidad. Ideal para quienes buscan uñas resistentes con acabado impecable y elegante."
      />
      <NailServiceCard
        title="French tips"
        image="/images/nails/nails-services/french-tips.webp"
        description="Clásico y atemporal. Bordes blancos limpios sobre base natural rosada para un look cuidado y refinado que nunca pasa de moda."
      />
      <NailServiceCard
        title="Spa pedicure"
        image="/images/nails/nails-services/spa-pedicure.webp"
        description="Pedicure de lujo que incluye exfoliación, masaje, cuidado de uñas y esmalte de larga duración. Un momento de relajación total para tus pies."
      />
      <NailServiceCard
        title="Diseños personalizados"
        image="/images/nails/nails-services/nails-art-design.webp"
        description="Expresa tu personalidad con diseños de nail art hechos a mano — desde patrones minimalistas hasta diseños audaces y personalizados."
      />
    </div>
  </section>
  <!--- Lightbox Gallery --->
  <GallerySlider client:visible />
  <!--- Por qué elegir AURA --->
  <section
    class="relative w-full h-[85vh] md:h-[80vh] flex items-center justify-center text-white overflow-hidden px-5 py-10"
    aria-labelledby="why-choose-aura-subtitle"
  >
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover z-0"
    >
      <source src="/videos/nails/nails-video.mp4" type="video/mp4" />
    </video>

    <div class="absolute inset-0 bg-black/60 z-10" aria-hidden="true"></div>

    <div class="relative z-20 max-w-3xl mx-auto text-center px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-6" id="why-choose-aura-subtitle">
        ¿Por qué elegir AURA?
      </h2>
      <ul class="space-y-3 text-lg text-left max-w-md mx-auto mb-10">
        <li class="flex items-center gap-3">
          <i class="fas fa-check-circle text-[#AE9380] text-xl"></i>
          Especialistas en uñas con técnica y experiencia
        </li>
        <li class="flex items-center gap-3">
          <i class="fas fa-check-circle text-[#AE9380] text-xl"></i>
          Herramientas limpias y esterilizadas
        </li>
        <li class="flex items-center gap-3">
          <i class="fas fa-check-circle text-[#AE9380] text-xl"></i>
          Productos de calidad profesional y larga duración
        </li>
        <li class="flex items-center gap-3">
          <i class="fas fa-check-circle text-[#AE9380] text-xl"></i>
          Diseños personalizados y asesoría de color
        </li>
        <li class="flex items-center gap-3">
          <i class="fas fa-check-circle text-[#AE9380] text-xl"></i>
          Ambiente cálido y atención genuina
        </li>
      </ul>
      <a
        href="https://wa.me/50767925695"
        target="_blank"
        rel="noopener noreferrer"
        class="button-secondary"
        aria-label="Agendar cita de uñas por WhatsApp"
        title="Agendar cita en AURA Beauty Salon"
      >
        Reservar cita
      </a>
    </div>
  </section>
  <Footer />
</Layout>

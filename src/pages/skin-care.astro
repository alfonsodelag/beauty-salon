---
import Layout from "@layouts/Layout.astro";
import NavigationBar from "@components/Navigation";
import Footer from "@components/Footer.astro";
---

<Layout title="AURA Beauty Salon | Servicios">
  <NavigationBar client:load />
  <section class="min-h-screen flex flex-col justify-center items-center gap-8 px-5 bg-[#FFF8F1]">
    <h1 class="text-4xl text-center text-[#6F5141]">Este servicio no está disponible</h1>
    <p class="text-xl text-[#75665F] text-center max-w-xl">
      AURA Beauty Salon se especializa en cabello, uñas y pestañas. Explora todos nuestros servicios disponibles.
    </p>
    <a
      href="/services"
      class="button-secondary"
      title="Ver todos los servicios de AURA Beauty Salon"
    >
      Ver todos los servicios
    </a>
  </section>
  <Footer />
</Layout>

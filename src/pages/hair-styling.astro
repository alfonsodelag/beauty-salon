---
import Layout from "@layouts/Layout.astro"
import NavigationBar from "@components/Navigation"
import HairStylingServices from "@components/HairStyling/HairStylingServices"
import Footer from "@components/Footer.astro"
---

<Layout title="AURA Beauty Salon | Cabello">
  <NavigationBar client:load />
  <!--- Banner Section --->
  <section
    id="hair-styling-banner"
    role="banner"
    class="relative w-full min-h-[90vh] max-h-[90vh] flex flex-col justify-center items-center"
    aria-labelledby="hair-styling-title"
  >
    <div id="hair-styling-banner-fig" class="w-full absolute right-0 -z-10 max-h-[90vh]">
      <img
        class="w-full max-h-[90vh] min-h-[90vh] object-cover object-top -z-15"
        src="/images/hair-styling/home-hourlies-bg.webp"
        alt="Estilista trabajando en AURA Beauty Salon, San Francisco, Panamá"
      >
    </div>
    <div class="flex flex-col justify-center items-center gap-5 relative px-3">
      <h1 class="text-4xl text-center text-white text-shadow" id="hair-styling-title">
        Cabello con técnica y estilo
      </h1>
      <p class="text-center md:w-8/12 text-xl text-white text-shadow">
        Cortes, balayage, morenas iluminadas, mechas y peinados diseñados para realzar tu belleza natural.
      </p>
      <div class="flex justify-center items-center gap-5 flex-wrap">
        <a
          href="https://wa.me/50767925695"
          target="_blank"
          rel="noopener noreferrer"
          class="white-button text-white"
          title="Agendar cita de cabello por WhatsApp"
          aria-label="Agendar cita en AURA Beauty Salon por WhatsApp"
        >
          Agendar cita
        </a>
        <a
          href="#hair-services-section"
          class="button-secondary"
          title="Ver todos los servicios de cabello"
          aria-label="Ver servicios de cabello en AURA Beauty Salon"
        >
          Ver servicios
        </a>
      </div>
    </div>
  </section>
  <!--- Accordion --->
  <section
    class="w-full flex flex-col gap-10 px-2 py-10 md:px-4"
    aria-labelledby="hair-styling-services-subtitle"
    id="hair-services-section"
  >
    <article
      class="w-full flex flex-col lg:flex-row justify-center gap-10"
      aria-label="Servicios de cabello - acordeón interactivo"
    >
      <HairStylingServices client:visible />
      <figure class="w-full hidden lg:block md:w-6/12 md:pt-10 md:pr-10 lg:w-5/12">
        <img
          src="/images/hair-styling/hair-services.webp"
          class="min-w-full w-full"
          alt="Cabello saludable y brillante después de tratamiento en AURA Beauty Salon"
          loading="lazy"
        >
      </figure>
    </article>
  </section>
  <!--- Video --->
  <section class="relative w-full h-[85vh] overflow-hidden" aria-label="Video de ambiente del salón">
    <video
      autoplay
      loop
      muted
      playsinline
      class="absolute inset-0 w-full h-full object-cover object-[35%] md:object-center brightness-60"
      src="/videos/hair-styling/hair-wash.mp4"
    ></video>
    <div class="relative z-10 flex flex-col items-center justify-center h-full text-center text-white px-4">
      <h2 class="text-3xl md:text-5xl font-bold mb-4 text-shadow">
        Técnica, estilo y cuidado
      </h2>
      <p class="max-w-2xl text-xl text-shadow">
        Porque tu cabello merece más que un corte — merece cuidado profesional, atención personalizada y el toque de quienes saben lo que hacen.
      </p>
    </div>
  </section>
  <!--- Quality Items --->
  <section
    class="w-full min-h-[85vh] flex flex-col justify-center items-center lg:flex-row gap-10 lg:pl-5 py-10"
    aria-label="Nuestro compromiso con tu cabello"
    id="quality-items-section"
  >
    <figure class="w-11/12 lg:w-5/12 flex justify-center items-center md:mt-10" id="items-img-fig">
      <img
        src="/images/hair-styling/items-img.webp"
        loading="lazy"
        alt="Herramientas y productos de estilismo en AURA Beauty Salon"
        title="Productos de calidad en AURA Beauty Salon"
        class="w-full"
      >
    </figure>
    <article class="w-11/12 lg:w-5/12 flex flex-col justify-center">
      <h2 class="text-[#AE9380] text-3xl mb-5">Nuestro compromiso contigo</h2>
      <ul class="w-full flex flex-col gap-5 mb-5" role="list">
        <li class="flex items-start gap-3 text-white">
          <i class="fa-regular fa-circle-check text-[#AE9380] text-xl mt-1" aria-hidden="true"></i>
          Estilistas profesionales con técnica y experiencia comprobada
        </li>
        <li class="flex items-start gap-3 text-white">
          <i class="fa-regular fa-circle-check text-[#AE9380] text-xl mt-1" aria-hidden="true"></i>
          Consulta personalizada antes de cada servicio
        </li>
        <li class="flex items-start gap-3 text-white">
          <i class="fa-regular fa-circle-check text-[#AE9380] text-xl mt-1" aria-hidden="true"></i>
          Productos de alta calidad en cada tratamiento
        </li>
        <li class="flex items-start gap-3 text-white">
          <i class="fa-regular fa-circle-check text-[#AE9380] text-xl mt-1" aria-hidden="true"></i>
          Ambiente relajante y atención cálida desde el primer momento
        </li>
        <li class="flex items-start gap-3 text-white">
          <i class="fa-regular fa-circle-check text-[#AE9380] text-xl mt-1" aria-hidden="true"></i>
          Compromiso con la salud y vitalidad de tu cabello
        </li>
        <li class="flex items-start gap-3 text-white">
          <i class="fa-regular fa-circle-check text-[#AE9380] text-xl mt-1" aria-hidden="true"></i>
          Un equipo que escucha y entiende lo que quieres
        </li>
      </ul>
      <div
        class="w-full flex flex-col justify-center items-center sm:flex-row sm:justify-start gap-5 py-5"
        aria-label="Botones de acción"
      >
        <a
          href="https://wa.me/50767925695"
          target="_blank"
          rel="noopener noreferrer"
          class="button-secondary min-w-full w-full text-center sm:min-w-fit font-medium shadow-md"
          title="Agendar cita por WhatsApp"
          aria-label="Agendar cita por WhatsApp en AURA Beauty Salon"
        >
          Reservar cita
        </a>
        <a
          href="/about"
          class="white-button text-white min-w-full w-full text-center sm:min-w-fit font-medium shadow-md"
          title="Conocer más sobre AURA Beauty Salon"
          aria-label="Conocer más sobre AURA Beauty Salon"
        >
          Sobre nosotros
        </a>
      </div>
    </article>
  </section>
  <!--- Footer --->
  <Footer />
</Layout>

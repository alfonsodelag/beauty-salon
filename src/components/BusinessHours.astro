---
import { businessHours } from "@data/salonInfo"

const { monday, tuesday, wednesday, thursday, friday, saturday, sunday } = businessHours
---

<section
  id="hourlies-section"
  class="min-h-screen flex flex-col justify-center items-center gap-8"
  aria-labelledby="hourlies-subtitle"
>
<h2 class="text-4xl text-white text-shadow" id="hourlies-subtitle">
  Horario <i class="fa-regular fa-clock" aria-hidden="true"></i>
</h2>
<dl class="text-white text-2xl flex flex-col items-center gap-3 text-shadow">
  <div>
    <dt class="inline font-semibold">Lunes:</dt> <dd class="inline ml-2">{monday}</dd>
  </div>
  <div><dt class="inline font-semibold">Martes:</dt> <dd class="inline ml-2">{tuesday}</dd></div>
  <div><dt class="inline font-semibold">Miércoles:</dt> <dd class="inline ml-2">{wednesday}</dd></div>
  <div><dt class="inline font-semibold">Jueves:</dt> <dd class="inline ml-2">{thursday}</dd></div>
  <div><dt class="inline font-semibold">Viernes:</dt> <dd class="inline ml-2">{friday}</dd></div>
  <div><dt class="inline font-semibold">Sábado:</dt> <dd class="inline ml-2">{saturday}</dd></div>
  <div><dt class="inline font-semibold">Domingo:</dt> <dd class="inline ml-2">{sunday}</dd></div>
</dl>
<a
  href="https://wa.me/50767925695"
  target="_blank"
  rel="noopener noreferrer"
  class="white-button text-white text-shadow hover-shadowless"
  aria-label="Agendar cita por WhatsApp en AURA Beauty Salon"
  title="Agendar cita por WhatsApp"
>
  Reservar cita <i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
</a>
</section>